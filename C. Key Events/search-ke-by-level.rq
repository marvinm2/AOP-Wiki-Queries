# title: Search Key Events by biological level
# description: Returns Key Events with their labels and biological organization levels. Choose a level or leave as All.
# category: Key Events
# param: level|enum:All,Molecular,Cellular,Tissue,Organ,Individual,Population|All|Biological level

SELECT DISTINCT ?ke ?label ?bioLevel
WHERE {
  ?ke a aopo:KeyEvent ;
    dc:title ?label ;
    nci:C25664 ?bioLevel .
  # Optional level filter — "All" returns every level.
  FILTER("{{level}}" = "All" || ?bioLevel = "{{level}}")
}
ORDER BY ?bioLevel
