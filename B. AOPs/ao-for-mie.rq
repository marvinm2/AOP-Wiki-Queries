# title: Find AOs for all MIEs
# description: Returns Molecular Initiating Event to Adverse Outcome links across all AOPs. Leave the MIE filter blank for all MIEs, or enter an event id to focus on one.
# category: AOPs
# param: mie_id|string||Filter by MIE event id (blank = all)

SELECT DISTINCT ?MIE ?MolecularInitiatingEventName ?AOwebpage ?AdverseOutcomeName
WHERE {
  # Optional MIE filter — blank mie_id returns all MIEs.
  FILTER("{{mie_id}}" = "" || ?MIE = aop.events:{{mie_id}})
  ?MIE dc:identifier ?MIELookup ;
    dc:title ?MolecularInitiatingEventName .
  ?AOPwebpage a aopo:AdverseOutcomePathway ;
    aopo:has_molecular_initiating_event ?MIELookup ;
    aopo:has_adverse_outcome ?AOwebpage .
  ?AOwebpage dc:title ?AdverseOutcomeName .
}
