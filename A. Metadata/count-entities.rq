# title: Count all entities
# description: Returns the total number of AOPs, Key Events, Key Event Relationships, and Stressors in the AOP-Wiki RDF.
# category: Metadata

SELECT
  (COUNT(DISTINCT ?aop) AS ?total_AOPs)
  (COUNT(DISTINCT ?ke) AS ?total_KEs)
  (COUNT(DISTINCT ?ker) AS ?total_KERs)
  (COUNT(DISTINCT ?stressor) AS ?total_Stressors)
WHERE {
  OPTIONAL { ?aop a aopo:AdverseOutcomePathway . }
  OPTIONAL { ?ke a aopo:KeyEvent . }
  OPTIONAL { ?ker a aopo:KeyEventRelationship . }
  OPTIONAL { ?stressor a nci:C54571 . }
}
